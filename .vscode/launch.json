{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Server + Gateway - Rebuild Components",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")\" && ./dev-sync.sh"
      },
      {
        "name": "Server + Gateway - Rebuild Components (fast)",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")\" && ./dev-sync-fast.sh"
      },
      {
        "name": "PyPI Publish",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")\" && ./scripts/publish-pypi.sh"
      },
      {
        "name": "Gateway Start",
        "type": "debugpy",
        "request": "launch",
        "python": "${workspaceFolder}\\hiroserver\\.venv\\Scripts\\python.exe",
        "module": "hirogateway.main",
        "args": ["start", "--foreground"],
        "cwd": "${workspaceFolder}\\hiroserver",
        "env": {
          "HIRO_ENV": "dev",
          "PYTHONPATH": "${workspaceFolder}\\hiroserver\\gateway\\src;${workspaceFolder}\\hiroserver\\hiro-channel-sdk\\src"
        },
        "console": "integratedTerminal",
        "justMyCode": false
      },
      {
        "name": "Server Start",
        "type": "debugpy",
        "request": "launch",
        "python": "${workspaceFolder}\\hiroserver\\.venv\\Scripts\\python.exe",
        "program": "${workspaceFolder}\\hiroserver\\.venv\\Scripts\\hiro.exe",
        "args": ["start", "--foreground", "--admin"],
        "cwd": "${workspaceFolder}\\hiroserver",
        "env": {
          "HIRO_ENV": "dev",
          "PYTHONPATH": "${workspaceFolder}\\hiroserver\\hirocli\\src;${workspaceFolder}\\hiroserver\\hiro-channel-sdk\\src"
        },
        "console": "integratedTerminal",
        "justMyCode": false
      },
      {
        "name": "hirocli: pytest (admin)",
        "type": "debugpy",
        "request": "launch",
        "python": "${workspaceFolder}\\hiroserver\\.venv\\Scripts\\python.exe",
        "module": "pytest",
        "args": [
          "src/hirocli/admin/",
          "-v",
          "--tb=short"
        ],
        "cwd": "${workspaceFolder}\\hiroserver\\hirocli",
        "env": {
          "PYTHONPATH": "${workspaceFolder}\\hiroserver\\hirocli\\src;${workspaceFolder}\\hiroserver\\hiro-channel-sdk\\src"
        },
        "console": "integratedTerminal",
        "justMyCode": false
      },
      {
        "name": "hirocli: pytest (current file)",
        "type": "debugpy",
        "request": "launch",
        "python": "${workspaceFolder}\\hiroserver\\.venv\\Scripts\\python.exe",
        "module": "pytest",
        "args": [
          "${file}",
          "-v",
          "--tb=short"
        ],
        "cwd": "${workspaceFolder}\\hiroserver\\hirocli",
        "env": {
          "PYTHONPATH": "${workspaceFolder}\\hiroserver\\hirocli\\src;${workspaceFolder}\\hiroserver\\hiro-channel-sdk\\src"
        },
        "console": "integratedTerminal",
        "justMyCode": false
      },
      {
        "name": "Flutter - Codegen",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")/device_apps\" && ./dev.sh --codegen"
      },
      {
        "name": "Flutter - Build Web",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")/device_apps\" && ./dev.sh --web"
      },
      {
        "name": "Flutter - Run Web",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")/device_apps\" && HIRO_ENV=dev ./flutter_build.sh run --dart-define=HIRO_ENV=dev -d chrome --web-port 63000"
      },
      {
        "name": "Flutter - Build Android (arm64)",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")/device_apps\" && ./dev.sh --android"
      },
      {
        "name": "Flutter - Run Android",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")/device_apps\" && HIRO_ENV=dev ./flutter_build.sh run --dart-define=HIRO_ENV=dev -d android"
      },
      {
        "name": "Flutter - List Outdated Packages",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")/device_apps\" && ./dev.sh --outdated"
      },
      {
        "name": "Flutter - Build All (codegen + web + android)",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")/device_apps\" && ./dev.sh --all"
      },
      {
        "name": "Admin Frontend Dev Server",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")\" && npm --prefix admin_frontend install && npm --prefix admin_frontend run dev"
      },
      {
        "name": "Website Dev Server",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder:hiroleague-website}\")\" && npm run dev"
      },
      {
        "name": "Mint Docs Start",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder:hiro-docs}\")/mintdocs\" && mint dev"
      },
      {
        "name": "Diagram Generator Start",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder:hiro-docs}\")\" && uv run python diagram-gen/generate.py"
      },
      {
        "name": "codebase_index_inspector",
        "type": "node-terminal",
        "request": "launch",
        "command": "cd \"$(cygpath \"${workspaceFolder}\")/utils/codebase_index_inspector\" && uv run python codebase_index_inspector.py --input \"${input:codebaseInspectorInput}\" --detail-max-lines 250"
      },
    ],
    "compounds": [
      {
        "name": "Server + Gateway - Start",
        "configurations": [
          "Gateway Start",
          "Server Start",
        ]
      },
      {
        "name": "Server + Gateway + Flutter device_apps",
        "configurations": [
          "Gateway Start",
          "Server Start",
          "Flutter - Run Web"
        ]
      }
    ],
    "inputs": [
      {
        "id": "codebaseInspectorInput",
        "type": "promptString",
        "description": "Path to embeddable/file list (one relative path per line)",
        "default": "c:/Users/augr/AppData/Roaming/Cursor/User/workspaceStorage/b8870fcbce9656c6b5aa06846882a66a/anysphere.cursor-retrieval/embeddable_files.txt"
      }
    ]
  }
  
