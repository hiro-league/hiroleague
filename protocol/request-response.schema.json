{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiroleague.local/protocol/request-response.schema.json",
  "title": "UnifiedMessageJsonRequestResponseBody",
  "oneOf": [
    {
      "type": "object",
      "required": ["method"],
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "params": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": ["status", "data"],
      "properties": {
        "status": { "const": "ok" },
        "data": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": ["status", "error"],
      "properties": {
        "status": { "const": "error" },
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  ]
}
